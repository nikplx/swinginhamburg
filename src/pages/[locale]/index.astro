---
export async function getStaticPaths() {
  const locales = ["en", "de"];
  return locales.map((locale) => ({
    params: { locale },
  }));
}

import "../../styles/global.css";
import Nav from "../../components/nav.astro";
import MapC from "../../components/map.astro";
import ClassC from "../../components/class.astro";
import WorkshopC from "../../components/workshop.astro";
import type { Class } from "../../../cms/src/payload-types.ts";
import { collect, payload, sortWeekdays, translateWeekday } from "../../utils";
import RichText from "../../components/richtText.astro";
import ResponsiveList from "../../components/responsiveList.astro";
import Layout from "../../components/layout.astro";
import ResponsiveListItem from "../../components/responsiveListItem.astro";

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.params as Params;

const { docs: classes } = await payload.find({
  collection: "classes",
  locale: locale,
});

const today = new Date();
const startOfToday = new Date(
  Date.UTC(
    today.getUTCFullYear(),
    today.getUTCMonth(),
    today.getUTCDate(),
    0,
    0,
    0,
    0,
  ),
);
const endOf14Days = new Date(
  Date.UTC(
    today.getUTCFullYear(),
    today.getUTCMonth(),
    today.getUTCDate() + 14,
    23,
    59,
    59,
    999,
  ),
);

// Get the current weekday name in English lowercase (e.g., "monday", "tuesday")
// to match the keys created by your .reduce(collect(...)) function
const currentWeekday = new Intl.DateTimeFormat("en-US", { weekday: "long" })
  .format(today)
  .toLowerCase();

const index = await payload.findGlobal({
  slug: "index",
  locale: locale,
});

// Fetches the data for the workshops tab
const { docs: upcomingEvents } = await payload.find({
  collection: "events",
  sort: "startDate",
  where: {
    and: [
      { startDate: { greater_than_equal: startOfToday.toISOString() } },
      { startDate: { less_than_equal: endOf14Days.toISOString() } },
    ],
  },
});

const groupedClasses = classes.sort(sortWeekdays).reduce(
  collect((c) => c.weekday.toLowerCase()),
  {},
);
---

<Layout locale={locale}>
  <section>
    <div class="greeter">
      <RichText content={index.intro} />
    </div>
    <div class="disclaimer-box">
      <div class="disclaimer">
        <RichText content={index.donationBox} />
      </div>
      <div class="disclaimer-button">
        <a href="">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="arrow-icon">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
          <span>{locale === "en" ? "Fill out Poll" : "Direkt zur Umfrage"}</span
          >
        </a>
      </div>
    </div>
  </section>
  <div class="page-tabs">
    <button id="tab-classes" class="tab active" data-tab="classes"
      >{locale === "en" ? "CLASSES" : "KURSE"}</button
    >
    <span class="tab-separator">|</span>
    <button id="tab-workshops" class="tab inactive" data-tab="workshops"
      >{locale === "en" ? "WORKSHOPS" : "WORKSHOPS"}</button
    >
  </div>

  <section>
    <div id="content-classes" class="tab-content active-content">
      <ResponsiveList maxColumns="1">
        {
          Object.entries(groupedClasses).map(([weekday, dayClasses], index) => {
            // 1. Check if this item matches today's weekday
            const isToday = weekday === currentWeekday;

            // 2. Fallback check: If today has no classes, default open the first day in the object
            const hasTodayClasses =
              Object.keys(groupedClasses).includes(currentWeekday);
            const shouldDefaultOpen = !hasTodayClasses && index === 0;

            return (
              <ResponsiveListItem
                title={translateWeekday(weekday, locale)}
                id={weekday.toLowerCase()}
                isOpen={isToday || shouldDefaultOpen}>
                <div class="centered-list">
                  {dayClasses.map((data) => (
                    <ClassC classs={data} />
                  ))}
                </div>
              </ResponsiveListItem>
            );
          })
        }
      </ResponsiveList>
    </div>

    <div id="content-workshops" class="tab-content">
      <div class="centered-list">
        {
          upcomingEvents.length > 0 ? (
            upcomingEvents.map((event) => <WorkshopC event={event} />)
          ) : (
            <p>No upcoming events in the next 14 days.</p>
          )
        }
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const tabClasses = document.getElementById("tab-classes");
      const tabWorkshops = document.getElementById("tab-workshops");
      const contentClasses = document.getElementById("content-classes");
      const contentWorkshops = document.getElementById("content-workshops");

      function switchTab(
        activeBtn,
        inactiveBtn,
        activeView,
        inactiveView,
        updateHash = true,
      ) {
        if (activeBtn.classList.contains("active")) return;

        // Update URL Hash for back-button support
        if (updateHash) {
          window.location.hash = activeBtn.dataset.tab;
        }

        activeBtn.classList.remove("inactive");
        activeBtn.classList.add("active");
        inactiveBtn.classList.remove("active");
        inactiveBtn.classList.add("inactive");

        // Direct swap for the initial load, fade for manual clicks
        if (!updateHash) {
          inactiveView.style.display = "none";
          inactiveView.classList.remove("active-content");
          activeView.style.display = "block";
          activeView.classList.add("active-content");
          activeView.style.opacity = "1";
        } else {
          inactiveView.style.opacity = "0";
          setTimeout(() => {
            inactiveView.classList.remove("active-content");
            inactiveView.style.display = "none";
            activeView.style.display = "block";
            void activeView.offsetWidth;
            activeView.classList.add("active-content");
            activeView.style.opacity = "1";
          }, 300);
        }
      }

      // Initialize from Hash
      const currentHash = window.location.hash.replace("#", "");
      if (currentHash === "workshops") {
        switchTab(
          tabWorkshops,
          tabClasses,
          contentWorkshops,
          contentClasses,
          false,
        );
      }

      if (tabClasses && tabWorkshops) {
        tabClasses.addEventListener("click", () => {
          switchTab(tabClasses, tabWorkshops, contentClasses, contentWorkshops);
        });

        tabWorkshops.addEventListener("click", () => {
          switchTab(tabWorkshops, tabClasses, contentWorkshops, contentClasses); // Note: Fix typo contentKurse -> contentClasses if needed
        });
      }

      // Day Accordion Toggling Logic
      const dayHeaders = document.querySelectorAll(".day-header");
      dayHeaders.forEach((header) => {
        header.addEventListener("click", () => {
          const dayGroup = header.parentElement;
          if (!dayGroup) return;

          const isOpen = dayGroup.classList.contains("open");
          if (isOpen) {
            dayGroup.classList.remove("open");
            header.setAttribute("aria-expanded", "false");
          } else {
            dayGroup.classList.add("open");
            header.setAttribute("aria-expanded", "true");
          }
        });
      });
    });
  </script>
</Layout>

<style>
  .greeter {
    padding-top: 30px;
  }

  .disclaimer-box {
    display: flex;
    flex-direction: column; 
    align-items: stretch;    
    border: 1px solid #000000; 
    padding: 24px; 
    border-radius: 12px; 
    width: 100%;
    max-width: 600px; 
    box-sizing: border-box;
    margin-bottom: 50px;
    gap: 16px; 
  }

  .disclaimer {
    font-family: sans-serif; 
    font-size: 1.1rem;
    line-height: 1.4;
    color: #000000;
  }

  .disclaimer :global(p) {
    margin: 0; 
  }

  .disclaimer-button {
    display: flex;
    justify-content: flex-start; 
    align-items: center;
    width: 100%;
  }

  .disclaimer-box a {
    display: inline-flex; 
    align-items: center;      /* Vertically aligns arrow and text perfectly */
    justify-content: flex-start; 
    text-align: left;
    gap: 8px;                /* Consistent gap between arrow and text */

    color: #000000;
    text-decoration: none;
    font-weight: 800; 
    font-size: 1.3rem;
    line-height: 1;           /* Tight line height prevents text-box bounding shifts */
    cursor: pointer;
  }

  /* SVG Specific Styles */
  .arrow-icon {
    width: 1.25rem;           /* Scales proportionally with text sizing units */
    height: 1.25rem;
    flex-shrink: 0;           /* Prevents the arrow from squeezing on ultra-small screens */
    display: inline-block;
  }
</style>
