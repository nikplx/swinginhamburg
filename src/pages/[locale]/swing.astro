---
export async function getStaticPaths() {
  const locales = ["en", "de"];

  return locales.map((locale) => ({
    params: { locale },
  }));
}

import "../../styles/global.css";
import Nav from "../../components/nav.astro";
import MapC from "../../components/map.astro";
import ClassC from "../../components/class.astro";
import RichText from "../../components/richtText.astro";
import { payload, translateWeekday } from "../../utils";

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.params as Params;

const cnt = await payload.findGlobal({
  slug: "swing",
  locale: locale,
});


---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Swing in Hamburg</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>
  <body>
    <div class="page-container">
      <header>
        <Nav locale={locale} active="swing" />
        <div class="divider-light"></div>
        <h1>{cnt.title}</h1>
      </header>
      <div class="page-content">
        <RichText content={cnt.content} />
      </div>
    </div>
  </body>
</html>
