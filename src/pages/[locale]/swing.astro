---
export async function getStaticPaths() {
  const locales = ["en", "de"];
  return locales.map((locale) => ({
    params: { locale },
  }));
}

import "../../styles/global.css";
import Nav from "../../components/nav.astro";
import RichText from "../../components/richtText.astro";
import Grid from "../../components/grid.astro";
import GridCard from "../../components/gridCard.astro"; // Import the card
import ResponsiveList from "../../components/responsiveList.astro";
import ResponsiveListItem from "../../components/responsiveListItem.astro";
import { payload } from "../../utils";
import Layout from "../../components/layout.astro";

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.params as Params;

// Fetch Global Swing Data
const cnt = await payload.findGlobal({
  slug: "swing",
  locale: locale,
});

const dancesResponse = await payload.find({
  collection: "dances",
  locale: locale,
  limit: 100,
});
const dances = dancesResponse.docs || [];
const order = ["Lindy", "Balboa", "Charleston", "Blues", "Shag", "Solo", "Tap"];

// Sort the dances array based on the index of the shortName in the order array
const sortedDances = dances.sort((a, b) => {
  return order.indexOf(a.shortName) - order.indexOf(b.shortName);
});
---

<Layout locale={locale}>
  <div class="page-content">
    <RichText content={cnt.whatIsSwing} />
  </div>

  {/* --- RESPONSIVE LIST 1: DANCES --- */}
  {
    sortedDances.length > 0 && (
      <ResponsiveList>
        {sortedDances.map((dance, index) => {
          return (
          <ResponsiveListItem title={dance.name} id={dance.shortName?.toLowerCase()} isOpen={false} border="dotted">
              <RichText
                style="white-space: pre-line; margin: 0;"
                content={dance.description}
              />
            </ResponsiveListItem>
          );
        })}
      </ResponsiveList>
    )
  }
  <div class="page-content">
    <RichText content={cnt.faq} />
  </div>
</Layout>

