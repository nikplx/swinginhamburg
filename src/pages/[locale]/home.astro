---
import StaggeredTitle from "../../components/StaggeredTitle.astro";
import TextRing from "../../components/TextRing.astro";
import { collect, payload, sortWeekdays, translateWeekday } from "../../utils";

export async function getStaticPaths() {
  const locales = ["en", "de"];

  return locales.map((locale) => ({
    params: { locale },
  }));
}

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.params as Params;

const { docs: classes } = await payload.find({
  collection: "classes",
  locale: locale,
});

const cnt = await payload.findGlobal({
  slug: "index",
  locale: locale,
});

const groupedClasses = classes.sort(sortWeekdays).reduce(
  collect((c) => c.weekday.toLowerCase()),
  {},
);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Swing in Hamburg</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css?family=Squada+One"
      rel="stylesheet"
    />
  </head>

  <body>
    <header class="site-header bg-texture-accent">
      <div class="logo-container">
        <div class="logo-circle"></div>
        <div class="logo-circle-inner bg-texture-accent"></div>
      </div>

      <nav class="site-nav">
        <ul class="nav-list lang-nav">
          <li><a href="#" class="nav-link">DE</a></li>
          <span>|</span>
          <li><a href="#" class="nav-link">EN</a></li>
        </ul>
        <ul class="nav-list page-nav">
          <li><a href="#" class="nav-link">Home</a></li>
          <li><a href="#" class="nav-link">About</a></li>
          <li><a href="#" class="nav-link">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <section id="greeter" class="greeter-section">
        <StaggeredTitle class="page-title-body" />
        <img
          class="greeter-image"
          src="/lindy_hop.png"
          alt="Lindy Hop Dancers"
        />
      </section>

      <section id="description" class="description-section bg-texture-accent">
        <h2 class="description-title">What is Lindy Hop?</h2>
        <p>
          Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam
          nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat,
          sed diam voluptua. At vero eos et accusam et justo duo dolores et ea
          rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem
          ipsum dolor sit amet.
        </p>
        <p>
          Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam
          nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat,
          sed diam voluptua. At vero eos et accusam et justo duo dolores et ea
          rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem
          ipsum dolor sit amet.
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    font-family: "Urbanist", sans-serif;

    --main-color-light: #f3f1d3;
    --accent-color-light: #58a6a0;
    --warn-color: #e45845;
    --warn-color-lighten10: #e6988d;
    --warn-color-darken: #762c22;

    --size-1x: 4px;
    --size-2x: 8px;
    --size-3x: 16px;
    --size-4x: 32px;
    --size-5x: 64px;
    --size-6x: 128px;
    --size-7x: 256px;
    --size-8x: 512px;
    --size-9x: 1024px;
    --size-10x: 2048px;

    --texture-accent:
      repeating-linear-gradient(
        45deg,
        var(--accent-color-light) 0%,
        var(--accent-color-light) 5%,
        transparent 5%,
        transparent 10%
      ),
      repeating-linear-gradient(
        135deg,
        var(--accent-color-light) 0%,
        var(--accent-color-light) 5%,
        transparent 5%,
        transparent 10%
      );
  }

  /* Global Box-Sizing Reset */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--main-color-light);
  }

  .bg-texture-accent {
    background: var(--texture-accent);
    background-size: 32px 32px;
    background-color: #6dcdc5;
  }

  /* --- Header & Navigation --- */
  .site-header {
    color: black;
    font-weight: 700;
    padding: var(--size-3x);
    display: flex;
    flex-direction: column; /* Mobile first: stacked */
    align-items: center;
    /* Desktop override */
    @media (min-width: 768px) {
      flex-direction: row;
      justify-content: space-between;
      height: var(--size-7x);
      padding: var(--size-2x);
    }
  }

  .logo-container {
    /* Fluid sizing: shrinks on small screens, maxes out at size-7x */
    display: none;
    @media (min-width: 768px) {
      width: clamp(150px, 40vw, var(--size-7x));
      aspect-ratio: 1; /* Keeps it perfectly square */
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
  }

  .logo-circle {
    width: 95%;
    height: 95%;
    background: linear-gradient(var(--warn-color), var(--warn-color-lighten10))
      var(--warn-color);
    border-radius: 50%;
    position: absolute;
    animation: spin linear 10s infinite;
  }

  .logo-circle-inner {
    width: 15%;
    border-radius: 50%;
    position: absolute;
    border: var(--size-4x) solid var(--warn-color);
  }

  .site-nav {
    display: flex;
    flex-direction: row;
    align-items: center; /* Center on mobile */
    justify-content: space-between;
    gap: var(--size-3x);
    width: 100%;
    height: 100%;

    @media (min-width: 768px) {
      align-items: flex-end; /* Right-align on desktop */
      padding: var(--size-4x);
      width: auto;
    }
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap; /* Allows wrapping if screen is too narrow */
    gap: var(--size-3x);
    align-items: center;
    font-size: var(--size-3x);
  }

  .lang-nav {
    display: none;
    font-size: var(--size-3x);

    @media (min-width: 768px) {
      display: contents;
      align-items: flex-end; /* Right-align on desktop */
      padding: var(--size-4x);
      width: auto;
    }
  }

  .nav-link {
    text-decoration: none;
    font-weight: 900;
    color: black;

    &:hover {
      text-decoration: underline;
    }
  }

  .warn-link {
    color: var(--warn-color-darken);
  }

  .nav-separator {
    color: var(--warn-color-darken);
  }

  /* --- Main Content Sections --- */
  .greeter-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(var(--size-2x), 5vw, var(--size-4x));
    width: 100%;
  }

  .greeter-image {
    margin-bottom: var(--size-3x);
    padding: var(--size-2x);
    background-color: white;
    /* Fluid image scaling */
    width: 100%;
    max-width: var(--size-7x);
    height: auto;
  }

  .description-section {
    /* Fluid padding to prevent horizontal scroll on mobile */
    padding: var(--size-4x) clamp(var(--size-3x), 10vw, var(--size-7x));
    color: var(--main-color-light);
  }

  .description-title {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    margin-top: 0;
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
</style>
