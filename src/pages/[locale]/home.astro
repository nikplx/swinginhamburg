---
import TextRing from "../../components/TextRing.astro";
import { collect, payload, sortWeekdays, translateWeekday } from "../../utils";

export async function getStaticPaths() {
  const locales = ["en", "de"];

  return locales.map((locale) => ({
    params: { locale },
  }));
}

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.params as Params;

const { docs: classes } = await payload.find({
  collection: "classes",
  locale: locale,
});

const cnt = await payload.findGlobal({
  slug: "index",
  locale: locale,
});

const groupedClasses = classes.sort(sortWeekdays).reduce(
  collect((c) => c.weekday.toLowerCase()),
  {},
);
