      margin: var(--size-4x);
      padding: var(--size-2x);
      width: var(--size-7x);
      background-color: white;
      margin-bottom: var(--size-6x);
    }

    h1.staggered {
      font-family: "Squada One";
      white-space: pre;
      font-size: var(--size-5x);
      font-weight: 900;
      position: relative;
      align-self: center;

      span:nth-child(even) {
        display: inline-block;
        transform: translateY(var(--size-2x));
