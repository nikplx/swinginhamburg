---
import "../styles/global.css";
import Nav from "../components/nav.astro";
import ClassC from "../components/class.astro";
import type {Class} from "../../cms/src/payload-types.ts"
import {collect, payload, sortWeekdays} from '../utils'

const {docs: classes} = await payload.find({
  collection: 'classes',
})

const groupedClasses = classes
  .sort(sortWeekdays)
  .reduce(collect((c) => c.weekday.toLowerCase()) , {});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Swing in Hamburg</title>
  </head>
  <body>
    <div class="page-container">
      <header>
        <h1>SWING IN HAMBURG</h1>
        <p class="subtitle">
          LISTINGS OF LINDY HOP CLASSES AND SOCIALS IN HAMBURG
        </p>
        <p class="last-updated">Last updated 3 days ago</p>
      </header>

      <section class="intro-grid">
        <div class="intro-left">
          <p>
            Swing in Hamburg lists all of the regular <a href="#"
              >Swing Dance Classes</a
            > in Hamburg which teach <a href="#">Lindy Hop</a>, Charleston,
            Balboa, Blues, Collegiate Shag and Authentic Jazz.
          </p>
          <p>
            It also lists all of the opportunities for <a href="#"
              >Social Dancing</a
            > to vintage jazz music.
          </p>
        </div>
        <div class="intro-right">
          <p>
            If you think something is missing or incorrect please email <a
              href="mailto:team@swinginhamburg.de">team@swinginhamburg.de</a
            > (but check the <a href="#">Listings Policy</a> first)
          </p>
          <div class="donate-box">
            <p>
              If you find Swing in Hamburg useful, please consider making a
              contribution to hosting costs:
            </p>
            <button class="donate-btn">Donate</button>
          </div>
        </div>
      </section>
      <Nav />

      <hr class="divider" />
      <p class="warning-text">
        Please note: The listings below are only a guide. Always check the
        source website before making any plans
      </p>

      <section class="content-grid">
        <div>
          <div class="column-header">
            <h2>LEARN!</h2>
            <h3>Weekly Classes</h3>
          </div>
          {
            Object.entries(groupedClasses).map(([weekday, dayClasses]) => (
              <div class="day-group">
                <div class="day-label">{weekday.toUpperCase()}</div>

                <div class="listing-items">
                  {dayClasses.map((data) => (
                    <ClassC classs={data} />
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <div>
          <div class="column-header">
            <h2>DANCE!</h2>
            <h3>Clubs and Social dancing</h3>
          </div>

          <p class="infrequent-note">
            N.B. Infrequent events are prefixed with a <span class="asterisk"
              >✽</span
            >
          </p>

          <div class="dashed-box">
            <h4 class="dashed-box-title">TODAY: Friday 20th March</h4>

            <div class="listing-item">
              <span class="postcode">SE1</span>
              <div class="listing-details">
                <span class="asterisk">✽</span>
                <span class="listing-title">Blues at the Brewery</span> - <span
                  class="listing-meta">Poulet in Bermondsey</span
                >
              </div>
            </div>
            <div class="listing-item">
              <span class="postcode">SE1</span>
              <div class="listing-details">
                <span class="asterisk">✽</span>
                <span class="listing-title">Pop Up Swing</span> - <span
                  class="listing-meta">Magdalen Hall in London Bridge</span
                >
              </div>
            </div>
          </div>

          <div style="padding: 0 20px;">
            <h4 class="dashed-box-title">TOMORROW: Saturday 21st March</h4>
            <div class="listing-item">
              <span class="postcode">EC2M</span>
              <div class="listing-details">
                <span class="asterisk">✽</span>
                <span class="listing-title"
                  >Swing Patrol "Meet our Scene" Ball</span
                > - <span class="listing-meta">The</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
