---
// src/components/responsiveList.astro
interface Props {
  maxColumns?: number;
  exclusiveOpen?: boolean; // Added configuration prop
}

const { maxColumns = 3, exclusiveOpen = true } = Astro.props;
---
<div class="responsive-list" id="responsive-list-wrapper" data-exclusive-open={exclusiveOpen.toString()}>
  <slot />
</div>

<script>
  // Helper function to close all accordion items
  function closeAllAccordions() {
    const allItems = document.querySelectorAll(".responsive-item");
    allItems.forEach((item) => {
      item.classList.remove("open");
      const header = item.querySelector(".responsive-item-header");
      if (header) {
        header.setAttribute("aria-expanded", "false");
      }
    });
  }

  // Function to open a specific accordion item exclusively
  function openAccordionById(id: string) {
    if (!id) return;
    
    const targetId = id.replace('#', '');
    const targetItem = document.getElementById(targetId);
    
    if (targetItem && targetItem.classList.contains('responsive-item')) {
      const isExclusive = targetItem.closest('.responsive-list')?.getAttribute('data-exclusive-open') === 'true';

      if (isExclusive) {
        closeAllAccordions();
      }
      
      targetItem.classList.add('open');
      const header = targetItem.querySelector('.responsive-item-header');
      if (header) {
        header.setAttribute('aria-expanded', 'true');
      }
      
      targetItem.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  // Setup click listeners for mobile accordion toggle
  const responsiveHeaders = document.querySelectorAll(".responsive-item-header");
  responsiveHeaders.forEach((header) => {
    header.addEventListener("click", () => {
      const group = header.parentElement;
      if (!group) return;

      const isExclusive = group.closest('.responsive-list')?.getAttribute('data-exclusive-open') === 'true';
      const isOpen = group.classList.contains("open");
      
      if (isOpen) {
        group.classList.remove("open");
        header.setAttribute("aria-expanded", "false");
      } else {
        if (isExclusive) {
          closeAllAccordions();
        }
        group.classList.add("open");
        header.setAttribute("aria-expanded", "true");
      }
    });
  });

  // Check hash on initial page load
  if (window.location.hash) {
    setTimeout(() => {
      openAccordionById(window.location.hash);
    }, 100);
  }

  window.addEventListener('hashchange', () => {
    openAccordionById(window.location.hash);
  });
</script>

<style define:vars={{ maxColumns }}>
  .responsive-list {
    width: 100%;
    margin: 20px auto 40px auto;
  }

  /* Desktop Grid Layout */
  @media (min-width: 768px) {
    .responsive-list {
      display: grid;
      grid-template-columns: repeat(var(--maxColumns), 1fr);
      gap: 30px;
    }
  }
</style>