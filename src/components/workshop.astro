---
import RichText from "./richtText.astro";
import type { Event } from "../../cms/src/payload-types.ts";
import { decodeAddress } from "../utils";

interface Props {
  event: Event;
}
const { event } = Astro.props;

// Helper formats date as DD.MM (No trailing dot)
const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return `${d.getUTCDate().toString().padStart(2, "0")}.${(d.getUTCMonth() + 1).toString().padStart(2, "0")}.`;
};

const getFormattedDate = () => {
  const startD = formatDate(event.startDate);
  const endD = event.endDate ? formatDate(event.endDate) : null;

  let datePart = startD;

  if (endD && startD !== endD) {
    const startParts = startD.split("."); // Expects [DD, MM, ""]
    const endParts = endD.split("."); // Expects [DD, MM, ""]

    // If months match: e.g., "17.-19.06."
    if (startParts[1] === endParts[1]) {
      datePart = `${startParts[0]}.-${endParts[0]}.${startParts[1]}.`;
    } else {
      // If months differ: e.g., "30.06.-02.07."
      datePart = `${startD}-${endD}.`;
    }
  }

  return datePart;
};


const address = decodeAddress(event.address);

const danceTags =
  event.dances && event.dances.length > 0
    ? event.dances.map((dance) =>
        typeof dance === "string" ? dance : dance.shortName,
      )
    : [event.title];
---

<div class="workshop-item">
  <div class="workshop-date">
    {getFormattedDate()}
  </div>

  <h3 class="workshop-title">{event.title}</h3>

  <div class="workshop-location">
    {
      event.locationName && (
        <>
          <strong>{event.locationName}</strong>
          <> |</>
        </>
      )
    }
    {address.street}
    {address.num}, {address.quarter}
  </div>

  {/* Wrap description in a container to manage the collapse states */}
  <div class="workshop-desc-container collapsed">
    <div class="workshop-desc">
      {
        typeof event.description === "string" ? (
          <p>{event.description}</p>
        ) : (
          <RichText content={event.description} />
        )
      }
    </div>
    <button class="toggle-desc-btn" aria-expanded="false">
      <span>Show more</span>
    </button>
  </div>

  <div class="listing-tags-row">
    {/* Grouping the tags together allows them to flex/wrap safely inside their own container */}
    <div class="workshop-tags-group">
      {
        danceTags.map((tag) => {
          // Standardize the slug for the link
          const slug = typeof tag === "string" ? tag : tag.shortName;
          const href = `/${Astro.currentLocale}/swing#${slug.replace(/\s+/g, "-").toLowerCase()}`;

          return (
            <a href={href} class="listing-tag">
              {tag}
            </a>
          );
        })
      }
    </div>
    {
      event.price !== null && (
        <div class="workshop-price">{event.price.toFixed(2)} €</div>
      )
    }
  </div>
</div>

<script>
  // Setup toggle handlers for mobile collapse
  const containers = document.querySelectorAll(".workshop-desc-container");

  containers.forEach((container) => {
    const button = container.querySelector(".toggle-desc-btn");
    const span = button?.querySelector("span");

    button?.addEventListener("click", () => {
      const isCollapsed = container.classList.toggle("collapsed");
      button.setAttribute("aria-expanded", (!isCollapsed).toString());
      if (span) {
        span.textContent = isCollapsed ? "Show more" : "Show less";
      }
    });
  });
</script>

<style>
  /* --- Workshops Layout (Mockup 3) --- */
  .workshop-item {
    margin-bottom: 15px;
    border-bottom: 2px dotted var(--text-main);
    padding-bottom: 10px;
  }

  .workshop-date {
    background-color: var(--accent);
    color: var(--bg-main);
    display: inline-block;
    border-radius: 8px;
    padding: 4px 8px;
    font-weight: 600;
    font-size: var(--font-desc);
    margin-bottom: 15px;
  }

  /* Price styling changes: margins handled by flex container */
  .workshop-price {
    font-size: var(--font-desc);
    font-weight: 700;
    color: var(--text-main);
    white-space: nowrap; /* Keeps the price on a single line */
    margin-left: auto;   /* Pushes the price completely to the right edge */
  }

  .workshop-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 10px 0;
    letter-spacing: 0.02em;
  }

  .workshop-location {
    font-size: var(--font-desc);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .workshop-location strong {
    font-weight: 700;
  }

  .workshop-desc {
    font-size: var(--font-tag);
    opacity: 0.7;
    line-height: 1.5;
  }

  /* Switch layout from strict Grid to a fluid Flex container */
  .listing-tags-row {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 20px;
    width: 100%;
  }

  /* Internal tag container allows multi-tag lists to wrap left smoothly */
  .workshop-tags-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    flex: 1; /* Automatically stretches to full remaining width if no price exists */
  }

  /* --- Mobile Collapsible Logic --- */

  /* Desktop defaults: Hide the toggle button */
  .toggle-desc-btn {
    display: none;
  }

  @media (max-width: 768px) {
    .workshop-desc-container {
      position: relative;
      margin-bottom: 10px;
    }

    /* Collapsed state constraints */
    .workshop-desc-container.collapsed .workshop-desc {
      max-height: 4.5em; /* Approximately 3 lines of text */
      overflow: hidden;
      position: relative;
    }

    /* Fading Overlay effect when collapsed */
    .workshop-desc-container.collapsed .workshop-desc::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2.5em;
      background: linear-gradient(
        to bottom,
        transparent,
        var(--bg-main, #fff) 90%
      );
      pointer-events: none;
    }

    /* Style button for mobile viewport */
    .toggle-desc-btn {
      display: block;
      background: none;
      border: none;
      color: var(--accent);
      font-size: var(--font-tag);
      font-weight: 600;
      padding: 4px 0;
      margin-top: 4px;
      cursor: pointer;
      text-decoration: underline;
    }
  }
</style>