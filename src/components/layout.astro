---
// src/layouts/Layout.astro
import "../styles/global.css";
import Nav from "../components/nav.astro";

interface Props {
  locale: "en" | "de";
  title?: string;
}

const { locale, title = "Swing in Hamburg" } = Astro.props;
---
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      /* Prevent the link from turning blue and underlined */
      .title-link {
        text-decoration: none;
        color: inherit;
      }
    </style>
  </head>
  <body>
    <div class="page-container">
      <header>
        <div class="header-top">
          {/* Ensure the empty <div> that was here is deleted! */}
          <div class="title-wrap">
            {/* Routes to /en or /de based on the current page. Change to href="/" if your root handles redirects */}
            <a href={`/${locale}`} class="title-link">
              <h1>SWING IN HAMBURG</h1>
            </a>
          </div>
          <Nav locale={locale} />
        </div>
      </header>

      <main class="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>