---
import "../styles/global.css";
import { payload, translateWeekday } from "../utils";
import type { School, Class } from "../../cms/src/payload-types";

interface Params {
  locale: "en" | "de";
}
const { locale } = Astro.props as Params;

const { docs: classes } = await payload.find({
  collection: "classes",
  locale: locale,
});

const events = classes.map((clazz) => {
  const school = clazz.school as School;
  const [loc, num, adr, quart] = clazz.address.split(",");
  const address = [loc, adr, num, quart].join(",");

  return {
    title: clazz.title,
    weekday: clazz.weekday,
    address: address,
    fullAddress: clazz.address,
    school: school.name,
    coordinates: [clazz.location[1], clazz.location[0]],
    dances: clazz.dances?.map((d) => d.shortName).join(", "),
  };
});
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<div class="map-wrapper">
  <div id="map"></div>

  <button class="mobile-filter-toggle" aria-expanded="false">
    <span class="icon">📅</span>
    {locale === "de" ? "Filter" : "Filters"}
  </button>

  <div class="filter-panel" id="filter-panel">
    <div class="filter-header-mobile">
      <h3>{locale === "de" ? "Nach Tag filtern" : "Filter by Day"}</h3>
      <button class="close-filter-btn" aria-label="Close filters">✕</button>
    </div>
    <h3 class="filter-header-desktop">
      {locale === "de" ? "Nach Tag filtern" : "Filter by Day"}
    </h3>

    <div class="filter-options">
      <button class="filter-btn active" data-day="all"
        >{locale === "de" ? "Alle Kurse" : "All Classes"}</button
      >
      <button class="filter-btn" data-day="Monday"
        >{translateWeekday("Monday", locale)}</button
      >
      <button class="filter-btn" data-day="Tuesday"
        >{translateWeekday("Tuesday", locale)}</button
      >
      <button class="filter-btn" data-day="Wednesday"
        >{translateWeekday("Wednesday", locale)}</button
      >
      <button class="filter-btn" data-day="Thursday"
        >{translateWeekday("Thursday", locale)}</button
      >
      <button class="filter-btn" data-day="Friday"
        >{translateWeekday("Friday", locale)}</button
      >
      <button class="filter-btn" data-day="Saturday"
        >{translateWeekday("Saturday", locale)}</button
      >
      <button class="filter-btn" data-day="Sunday"
        >{translateWeekday("Sunday", locale)}</button
      >
    </div>
  </div>
</div>

<script
  set:html={JSON.stringify(events)}
  is:inline
  id="event-data"
  type="application/json"
/>

<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
></script>

<script is:inline lang="ts">
  document.addEventListener("DOMContentLoaded", () => {
    // --- Map Initialization ---
    const map = L.map("map").setView([53.5511, 9.9937], 12);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "© OpenStreetMap",
    }).addTo(map);

    const eventDataElement = document.getElementById("event-data");
    const events = JSON.parse(eventDataElement.textContent);

    const markerLayer = L.layerGroup().addTo(map);

    function renderMarkers(dayFilter) {
      markerLayer.clearLayers();

      events.forEach((event) => {
        if (dayFilter === "all" || event.weekday === dayFilter) {
          const marker = L.marker(event.coordinates).bindPopup(
            `
        <div class="custom-popup-content">
          <strong>${event.school}</strong><br/>
          <span>${event.address}</span><br/>
          <div class="popup-date-time">
            ${event.weekday}
          </div>
          <div class="popup-title">${event.title} (${event.dances})</div>
        </div>
      `,
            {
              className: "custom-popup", // This links to the CSS below
              closeButton: false, // Hide default X button to match mockup
              offset: [0, -10],
            },
          );
          markerLayer.addLayer(marker);
        }
      });
    }

    renderMarkers("all");

    // --- Filter UI Logic ---
    const filterPanel = document.getElementById("filter-panel");
    const mobileToggleBtn = document.querySelector(".mobile-filter-toggle");
    const closeBtn = document.querySelector(".close-filter-btn");
    const filterButtons = document.querySelectorAll(".filter-btn");

    function toggleMobileDrawer() {
      if (window.innerWidth <= 768) {
        filterPanel.classList.toggle("open");
      }
    }

    if (mobileToggleBtn)
      mobileToggleBtn.addEventListener("click", toggleMobileDrawer);
    if (closeBtn) closeBtn.addEventListener("click", toggleMobileDrawer);

    filterButtons.forEach((button) => {
      button.addEventListener("click", (e) => {
        filterButtons.forEach((btn) => btn.classList.remove("active"));
        e.target.classList.add("active");

        const selectedDay = e.target.dataset.day;
        renderMarkers(selectedDay);

        if (window.innerWidth <= 768) {
          filterPanel.classList.remove("open");
        }
      });
    });
  });
</script>

<style>
  /* 1. Ensure the body fills the entire viewport */
  body {
    height: 100vh;
    height: 100dvh;
    overflow: hidden; /* Optional: prevents double scrollbars */
    display: flex;
    flex-direction: column;
  }

  .map-wrapper {
    position: relative;

    /* Forces the container to be exactly the width of the screen */
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);

    height: 600px;
    display: flex;
    overflow: hidden;
  }
  /* 2. Make the main content expand to fill remaining space */
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    /* Remove fixed padding if it interferes with the map sizing */
    padding: 0;
  }

  /* 3. Ensure the map container takes full height of the main-content */
  #map-container {
    /* Replace with your specific ID or class for the map div */
    flex: 1;
    width: 100%;
  }

  #map {
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* Filter Panel Base */
  .filter-panel {
    position: absolute;
    top: 20px;
    /* Aligns 20px from the right edge of the screen now */
    right: 20px;
    z-index: 1000;
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    max-width: 300px;
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Black and White Button Design */
  .filter-btn {
    background-color: #ffffff;
    color: #000000;
    border: 2px solid #000000;
    padding: 0.4rem 0.05rem;
    font-size: 0.8rem;
    font-weight: bold;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
    width: 100%;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background-color: #000000;
    color: #ffffff;
  }

  .mobile-filter-toggle,
  .filter-header-mobile {
    display: none;
  }

  .close-filter-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #000;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .mobile-filter-toggle {
      display: block;
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      background-color: #000000;
      color: #ffffff;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 30px;
      font-weight: bold;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
    }

    .filter-header-mobile {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .filter-header-desktop {
      display: none;
    }

    .filter-panel {
      position: fixed;
      top: auto;
      bottom: 0;
      right: 0;
      left: 0;
      max-width: 100%;
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
      transition: transform 0.3s ease-in-out;

      max-height: 85vh;
      overflow-y: auto;
      padding: 1.5rem 1.5rem 3rem 1.5rem;
    }

    .filter-panel.open {
      transform: translateY(0);
    }
  }

  #map :global(.leaflet-tile-pane) {
    filter: grayscale(100%) contrast(110%);
  }

  #map :global(.leaflet-marker-icon) {
    filter: grayscale(100%) contrast(150%);
  }
</style>

<style is:global>
  /* Container override */
  .custom-popup .leaflet-popup-content-wrapper {
    background: #ffffff;
    border-radius: 4px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    padding: 2px;
    width: 147px; /* From your mockup specs */
  }

  /* Remove default pointer/tip */
  .custom-popup .leaflet-popup-tip {
    display: none;
  }

  .custom-popup .leaflet-popup-content {
    margin: 12px;
    width: auto !important; /* Ensure it respects the wrapper width */
    font-family: 'Inter', sans-serif;
    color: var(--text-main);
    line-height: 1.2;
  }

  /* Custom internal styling */
  .custom-popup-content strong {
    font-size: 11pt;
    font-weight: 700;
    display: block;
  }

  .custom-popup-content span {
    font-size: 9pt;
    color: #333;
  }

  .popup-date-time {
    font-size: 9pt;
    font-style: italic;
    margin-top: 6px;
  }

  .popup-title {
    font-size: 9pt;
    font-weight: 500;
    margin-top: 2px;
  }
</style>
