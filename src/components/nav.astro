---
interface Props {
  locale: "de" | "en";
}

const { locale } = Astro.props;

// 1. Automatically determine the current path
const currentPath = Astro.url.pathname;

// 2. Helper to check if a link is the current active page
// We remove trailing slashes to ensure robust matching
const normalizePath = (path: string) => path.replace(/\/$/, "");
const isActive = (href: string) =>
  normalizePath(currentPath) === normalizePath(href);

// 3. i18n link configuration
const otherLocale = locale === "en" ? "de" : "en";
const otherLocaleLink = currentPath.replace(`/${locale}`, `/${otherLocale}`);

// Map your data structure for easy iteration
const navItems = [
  {
    href: `/${locale}`,
    label: locale === "en" ? "CLASSES | WORKSHOPS" : "KURSE | WORKSHOPS",
  },
  { href: `/${locale}/map`, label: locale === "en" ? "MAP" : "KARTE" },
  {
    href: `/${locale}/schools`,
    label: locale === "en" ? "SCHOOLS" : "TANZSCHULEN",
  },
  {
    href: `/${locale}/swing`,
    label: locale === "en" ? "GET STARTED" : "NEU HIER?",
  },
  { href: `/${locale}/about`, label: locale === "en" ? "ABOUT" : "ÜBER UNS" },
  /*   {
    href: `/${locale}/conduct`,
    label: locale === "en" ? "CODE OF CONDUCT" : "CODE OF CONDUCT",
  }, */
];
---

{/* Wrap the nav in a custom element for scoped Javascript */}
<mobile-nav>
  <nav class="site-nav">
    <button
      class="menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    {/* Iterate through links, removing the separator logic */}
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-item ${isActive(item.href) ? "active border-btn" : ""}`}>
            {item.label}
          </a>
        ))
      }

      <a class="lang-switch" href={otherLocaleLink}
        >{otherLocale.toUpperCase()}</a
      >
    </div>
  </nav>
</mobile-nav>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuToggle = document.querySelector(".menu-toggle");
    const navLinks = document.querySelector(".nav-links");

    if (menuToggle && navLinks) {
      // 1. Handle the toggle button click
      menuToggle.addEventListener("click", (event) => {
        // Prevent this click from immediately triggering the document listener below
        event.stopPropagation();
        menuToggle.classList.toggle("active");
        navLinks.classList.toggle("open");
      });

      // 2. The Click-Out Behavior
      document.addEventListener("click", (event) => {
        // Only run the check if the menu is actually open
        if (navLinks.classList.contains("open")) {
          // Check if the click happened inside the menu or on the toggle button
          const isClickInsideMenu = navLinks.contains(event.target);
          const isClickOnToggle = menuToggle.contains(event.target);

          // If clicked completely outside both, collapse the menu
          if (!isClickInsideMenu && !isClickOnToggle) {
            menuToggle.classList.remove("active");
            navLinks.classList.remove("open");
          }
        }
      });

      // 3. Accessibility Bonus: Close on Escape key
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && navLinks.classList.contains("open")) {
          menuToggle.classList.remove("active");
          navLinks.classList.remove("open");
        }
      });
    }
  });
</script>

<style>
  /* --- Desktop Styling Defaults --- */
  .lang-switch {
    /* Uses your global 8pt variant, or inherits and forces a smaller look */
    font-size: var(--font-xxs) !important;
    color: var(--text-muted) !important; /* #888888 */
    font-weight: 500;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.8;
  }

  .lang-switch:hover {
    color: var(
      --bg-main
    ) !important; /* Illuminates back to white against the black header background */
    opacity: 1;
    text-decoration: underline;
  }

  /* --- Mobile Responsive Rules (< 768px) --- */
  @media (max-width: 768px) {
    .lang-switch {
      /* Scales down smaller than standard mobile menu items (e.g., 10pt/12pt instead of var(--font-emph)) */
      font-size: var(--font-desc) !important;
      border-top: 1px dotted rgba(255, 255, 255, 0.2); /* Discrete line breaking it away from standard pages */
      padding-top: 15px !important;
      width: 60%; /* Caps width for clear layout line presentation */
      text-align: center;
    }

    .lang-switch:hover {
      color: var(--bg-main) !important;
      text-decoration: none;
    }
  }
</style>
