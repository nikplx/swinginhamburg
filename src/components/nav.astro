---
interface Params {
    locale: "de" | "en",
    active: "root" | "map" | "about" | "listings"
}
const {locale, active} = Astro.params
const c = (comp:string) => {
    if (comp == active) {
        return "nav-item active"
    } else {
        return "nav-item"
    }
}
---
<nav>
    <a href={"/" + locale} class={c("root")}>LISTINGS</a>
    <span>|</span>
    <a href={"/" + locale + "/map"} class={c("map")}>MAP</a>
    <span>|</span>
    <a href={"/" + locale + "/about"} class={c("about")}>ABOUT</a>
    <span>|</span>
    <a href={"/" + locale + "/listings"} class={c("listings")}>LISTINGS POLICY</a>
</nav>